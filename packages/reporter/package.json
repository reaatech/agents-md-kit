{
  "name": "@reaatech/agents-markdown-reporter",
  "version": "1.0.0",
  "description": "Multi-format output reporters for agents-markdown ecosystem",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agents-md-kit.git",
    "directory": "packages/reporter"
  },
  "homepage": "https://github.com/reaatech/agents-md-kit/tree/main/packages/reporter#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agents-md-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/agents-markdown": "workspace:*",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "~6.0.3",
    "vitest": "^3.1.1"
  }
}
