{
  "name": "@reaatech/agents-markdown-cli",
  "version": "1.0.0",
  "description": "CLI tool for agents-markdown ecosystem",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agents-md-kit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/reaatech/agents-md-kit/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agents-md-kit/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agents-md-kit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@reaatech/agents-markdown": "workspace:*",
    "@reaatech/agents-markdown-linter": "workspace:*",
    "@reaatech/agents-markdown-parser": "workspace:*",
    "@reaatech/agents-markdown-reporter": "workspace:*",
    "@reaatech/agents-markdown-scaffold": "workspace:*",
    "@reaatech/agents-markdown-validator": "workspace:*",
    "@reaatech/agents-markdown-observability": "workspace:*",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "vitest": "^3.1.1"
  }
}
