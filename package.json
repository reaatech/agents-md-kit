{
  "name": "agents-md-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for agents-md-kit — linter, validator, and scaffolding tool for AGENTS.md and SKILL.md files",
  "type": "module",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agents-md-kit.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/agents-md-kit/issues"
  },
  "homepage": "https://github.com/reaatech/agents-md-kit#readme",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.28.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "protobufjs"]
  }
}
