{
  "name": "agents-md-kit",
  "version": "1.0.0",
  "description": "Linter, validator, and scaffolding tool for AGENTS.md and SKILL.md files — the durable agent instruction artifacts.",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "agents-md-kit": "dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "keywords": [
    "agents",
    "markdown",
    "linting",
    "validation",
    "scaffolding",
    "mcp",
    "agent-development",
    "skill-system"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "dev": "npm run build && node --enable-source-maps dist/src/cli.js",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "chalk": "^5.4.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "pino": "^10.3.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.4",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "globals": "^17.5.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/agents-md-kit.git"
  },
  "homepage": "https://github.com/reaatech/agents-md-kit#readme",
  "bugs": {
    "url": "https://github.com/reaatech/agents-md-kit/issues"
  },
  "files": [
    "dist/src",
    "templates",
    "LICENSE",
    "README.md"
  ]
}
